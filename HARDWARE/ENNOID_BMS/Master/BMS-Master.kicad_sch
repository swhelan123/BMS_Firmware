			)
			(justify left bottom)
		)
		(uuid "8a77fe1e-1a4e-4655-b74e-f5dc627aaef3")
	)
	(text "Cooling doesnt appear to be in the firmware, this is probably something we want the bms to control\nmaybe like cooling_on if:\n\nmax_cell_temp > threshold\nOR charging_active"
		(exclude_from_sim no)
		(at 341.122 25.908 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8a7dbb3d-6b6c-4579-aed8-5eda8573f157")
	)
	(text "discharge should be replaced with new conditions to match the orion and what the shutdown circuit expects\nthey should be active low\n\nDISCHARGE_ENABLE_N\n\nThis should represent battery safe to discharge, with the following conditions:\n\ndischargeAllowed AND packInSOA AND all slaves communicating AND no open wire faults \nAND cell voltage within limits AND temperature within limits\n\nMULTIPURPOSE_ENABLE_N\n\nThis should represent Master alive and system operational with the following conditions\n\nMCU running AND watchdog serviced AND no firmware fatal fault AND system initialized"
		(exclude_from_sim no)
		(at 346.71 51.816 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a6c20d58-734f-4a62-ac6f-8a9c74d0d999")
	)
	(text "ISOLATED"
		(exclude_from_sim no)
