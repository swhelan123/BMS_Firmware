		)
		(uuid "79742949-4dcc-4125-96d5-11cd516eaede")
	)
	(text "charger should have additional signals with these conditions to create AMS ok signal for charger shutdown circuit\nCHARGE_ENABLE_N  = active-low \"pack may accept charge\"\n                 = chargeAllowed AND no critical fault\n\nCHARGER_SAFETY_N = active-low \"external charger may run\"\n                 = charger_detected\n                   AND charging_state_active\n                   AND chargeAllowed\n                   AND master_ok"
		(exclude_from_sim no)
		(at 347.98 81.534 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "81cadc05-b13e-4b28-8249-f678f0f97072")
	)
	(text "AIR 2"
		(exclude_from_sim no)
		(at 60.706 57.658 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8a012d88-6bab-4afb-8c46-b9e5efa151e8")
	)
	(text "ISOLATED"
		(exclude_from_sim no)
		(at 307.34 205.74 0)
		(effects
			(font
				(size 5.08 5.08)
				(thickness 1.016)
